<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Biodata Pengguna"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />
    <TextView
        android:id="@+id/txtNama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama: Ilham Novriadi"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtProdi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Program Studi: Teknik Informatika"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email: ilhamnovriadi@gmail.com"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />
    <TextView
        android:id="@+id/txtUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Username: -"
        android:textSize="18sp"
        android:layout_marginBottom="20dp" />
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchDarkMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode Gelap"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnBukaPeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buka Peta"
        android:backgroundTint="@color/black"
        app:cornerRadius="0dp"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:backgroundTint="@color/black"
        app:cornerRadius="0dp"/>
</LinearLayout>